// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  //output = "./generated/client"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  name             String    @unique
  hashedPassword   String?
  profileImg       String?
  level            Int       @default(1)
  badges           Int[]     @default([])
  pokemonIds       String[]  @db.ObjectId
  pokemons         Pokemon[] @relation
  userSix          Json      @default("[]")
  location         String    @default("shire")
  visitedLocations String[]  @default(["shire"])
  chapter          Int       @default(0)
  day              Int       @default(0)
  partOfDay        Int       @default(0)
  items            Json      @default("[]")
  contacts         String[]  @default(["prof. Bloom"])
  dailyMessage     Int       @default(0)
  Message          Message[]
  Quest            Quest[]
}

model Pokemon {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  type              String[]
  level             Int       @default(1)
  attacks           String[]  @default([])
  abilities         String[]  @default([])
  actualHp          Int       @default(10)
  hp                Int       @default(10)
  actualEnergy      Int       @default(5)
  energy            Int       @default(10)
  actualExp         Int       @default(0)
  expToLevel        Int       @default(100)
  damage            Int       @default(1)
  defense           Int       @default(1)
  speed             Int       @default(1)
  evolutionInformed Boolean?
  userId            String?   @db.ObjectId
  user              User?     @relation(fields: [userId], references: [id])
  Message           Message[]
}

enum MessageType {
  EVOLUTION
  NEW_MOVE
  QUEST
  DEFAULT
}

model Message {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  from      String
  type      MessageType
  text      String
  time      Int
  viewed    Boolean     @default(false)
  createAt  DateTime    @default(now())
  userId    String      @db.ObjectId
  user      User        @relation(fields: [userId], references: [id])
  pokemonId String?     @db.ObjectId
  pokemon   Pokemon?    @relation(fields: [pokemonId], references: [id])
}

model Quest {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String
  from        String
  startDay    Int?
  endDay      Int?
  location    String?
  rewards     Json        @default("[]")
  completed   Boolean     @default(false)
  user        User        @relation(fields: [userId], references: [id])
  userId      String      @db.ObjectId
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  objectives  Objective[]
  progress    Json        @default("{}")
}

model Objective {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  quest          Quest   @relation(fields: [questId], references: [id])
  questId        String  @db.ObjectId
  type           String
  target         String
  requiredAmount Int
  currentAmount  Int     @default(0)
  completed      Boolean @default(false)
}
